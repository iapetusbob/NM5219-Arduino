# Handle line endings automatically for files detected as text 
# and leave binary files alone.
* text=auto

# Explicitly declare text files to always be normalized (LF in repo)
# and converted to native line endings on checkout.
*.ino   text
*.cpp   text
*.h     text
*.c     text
*.md    text
*.txt   text
*.json  text
*.yml   text

# Denote all files that are truly binary and should not be modified.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary